<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            min-height: 100vh;
            padding: 40px;
            color: white;
        }

        .container {
            max-width: 1100px;
            margin: auto;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        h1 {
            text-align: center;
            margin-bottom: 25px;
            font-size: 2.5rem;
            color: #38bdf8;
        }

        form {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
            justify-content: center;
            flex-wrap: wrap;
        }

        input {
            padding: 14px 16px;
            width: 70%;
            max-width: 500px;
            border: none;
            border-radius: 10px;
            outline: none;
            font-size: 16px;
        }

        button {
            padding: 14px 24px;
            border: none;
            border-radius: 10px;
            background: #38bdf8;
            color: white;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s ease;
        }

        button:hover {
            background: #0ea5e9;
            transform: translateY(-2px);
        }

        .generated-link {
            text-align: center;
            margin-bottom: 20px;
            padding: 15px;
            background: rgba(56, 189, 248, 0.15);
            border: 1px solid #38bdf8;
            border-radius: 12px;
            color: #7dd3fc;
            word-break: break-all;
        }

        .generated-link a {
            color: #38bdf8;
            text-decoration: none;
            font-weight: bold;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 12px;
            margin-top: 20px;
        }

        thead {
            background: #38bdf8;
            color: white;
        }

        th,
        td {
            padding: 14px;
            text-align: center;
        }

        tbody tr {
            background: rgba(255, 255, 255, 0.06);
            transition: 0.3s ease;
        }

        tbody tr:hover {
            background: rgba(255, 255, 255, 0.12);
        }

        td a {
            color: #7dd3fc;
            text-decoration: none;
        }

        @media (max-width: 768px) {
            input {
                width: 100%;
            }

            button {
                width: 100%;
            }

            table {
                display: block;
                overflow-x: auto;
            }

            h1 {
                font-size: 2rem;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>🔗 URL Shortener</h1>

        <form method="post" action="/url">
            <input type="text" name="url" placeholder="Enter your URL (https://www.google.com)" required>
            <button type="submit">Generate</button>
        </form>

        <% if (locals?.id) { %>
            <div class="generated-link">
                Your Generated Link:
                <a href="/url/<%= id %>" target="_blank">
                    http://localhost:8001/url/<%= id %>
                </a>
            </div>
        <% } %>

        <% if (locals?.url) { %>
            <table>
                <thead>
                    <tr>
                        <th>Sr No</th>
                        <th>Short ID</th>
                        <th>Redirect URL</th>
                        <th>Analytics</th>
                    </tr>
                </thead>
                <tbody>
                    <% url.forEach((element, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td>
                                <a href="/url/<%= element.ShortId %>" target="_blank">
                                    <%= element.ShortId %>
                                </a>
                            </td>
                            <td>
                                <a href="<%= element.redirectUrl %>" target="_blank">
                                    <%= element.redirectUrl %>
                                </a>
                            </td>
                            <td><%= element.visitHistory.length %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>

</html>


